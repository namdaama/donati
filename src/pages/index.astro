---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Carousel from '../components/Carousel.astro';
import Footer from '../components/Footer.astro';
import { heroCarouselData } from '../config/site';

// お知らせデータ（4列グリッド用）
const newsItems = [
  {
    id: 1,
    thumbnail: '/images/news/event1.jpg',
    date: '2025/01 [土]',
    title: '1/18観察会～20:30時～',
    location: '駅前プラザ（ROOM A）',
    detail: '予約方法：Instagram DM',
    link: '/news/event1'
  },
  {
    id: 2,
    thumbnail: '/images/news/event2.jpg', 
    date: '2025/02 [日]',
    title: '2/15実験ショー～14:00時～',
    location: '市民会館（大ホール）',
    detail: '予約方法：Instagram DM',
    link: '/news/event2'
  },
  {
    id: 3,
    thumbnail: '/images/news/event3.jpg',
    date: '2025/02 [土]',
    title: '2/22ワークショップ～10:00時～',
    location: '科学館（実験室）',
    detail: '予約方法：Instagram DM',
    link: '/news/event3'
  },
  {
    id: 4,
    thumbnail: '/images/news/event4.jpg',
    date: '2025/03 [日]',
    title: '3/8星空観察～19:30時～',
    location: '山頂公園（観望台）',
    detail: '予約方法：Instagram DM',
    link: '/news/event4'
  }
];

// スタッフ情報（OverView.jpgデザインに合わせて更新）
const staffMembers = [
  {
    name: 'フジ',
    role: 'サイエンスコミュニケーター',
    pictSvg: '/images/svg/Parts/fuji_pict.svg',
    nameSvg: '/images/svg/Parts/fuji_name.svg'
  },
  {
    name: 'ひでゆき',
    role: '星空案内人',
    pictSvg: '/images/svg/Parts/hide_pict.svg',
    nameSvg: '/images/svg/Parts/hide_name.svg'
  }
];

// サービス内容（OverView.jpgデザインに合わせて更新）
const services = [
  'わくわく実験教室',
  'ワークショップ',
  '星空イベント',
  '星空の写真　など'
];

// 右カラムのリンク情報
const rightColumnLinks = [
  { title: '依頼の流れ', href: '/services', icon: '📋' },
  { title: 'よくある質問', href: '/services#faq', icon: '❓' },
  { title: '活動経歴', href: '/achievements', icon: '🏆' }
];
---

<Layout title="OverView - DONATI">
  <Header />
  
  <main class="flex-grow">
    <!-- Hero Carousel Section -->
    <div class="hero-carousel-wrapper">
      <Carousel slides={heroCarouselData} />
    </div>

    <!-- お知らせセクション -->
    <section class="py-16 md:py-24 bg-transparent">
      <div class="container mx-auto px-4">
        <!-- セクションタイトル -->
        <div class="text-left mb-12">
          <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-4" style="color: #65b7ec;">
            お知らせ
          </h2>
        </div>
      </div>

      <!-- ウェーブライン（containerの外） -->
      <div class="waveline-wrapper mb-12">
        <div class="flex justify-center">
          <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
          <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
          <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
          <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
          <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
        </div>
      </div>

      <div class="container mx-auto px-4">
        
        <!-- 4列グリッド -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {newsItems.map((item) => (
            <div class="bg-white/20 backdrop-blur-sm rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden border-2 border-overview-yellow/30">
              <!-- サムネイル -->
              <div class="h-40 bg-overview-sky/20 flex items-center justify-center">
                <span class="text-4xl">📅</span>
              </div>
              
              <!-- コンテンツ -->
              <div class="p-4">
                <div class="text-sm font-bold text-overview-yellow bg-overview-dark-blue px-3 py-1 rounded-full inline-block mb-3">
                  {item.date}
                </div>
                <h3 class="font-bold text-overview-dark-blue mb-2 text-lg">
                  {item.title}
                </h3>
                <p class="text-sm text-gray-600 mb-2">
                  {item.location}
                </p>
                <p class="text-xs text-overview-sky font-medium">
                  {item.detail}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 波線装飾（複数並べて中央寄せ） -->
    <div class="waveline-wrapper">
      <div class="overflow-hidden py-4 flex justify-center">
        <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
        <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
        <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
        <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
        <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-4 w-auto flex-shrink-0" />
      </div>
    </div>

    <!-- 下部3列セクション -->
    <section class="py-16 md:py-24 bg-transparent">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

          <!-- 1. 私たちについて -->
          <div class="bg-white/95 rounded-2xl shadow-lg p-6 overflow-hidden flex flex-col">
            <!-- セクションタイトル（SVG使用） -->
            <div class="text-center mb-4">
              <img src="/images/svg/Parts/text_AboutUs.svg" alt="私たちについて" class="h-7 mx-auto mb-2" />
              <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-3 mx-auto" />
            </div>

            <!-- スタッフ紹介（横並び） -->
            <div class="flex justify-center gap-6 mb-4 flex-grow">
              {staffMembers.map((staff) => (
                <div class="text-center">
                  <img src={staff.pictSvg} alt={staff.name} class="w-24 h-24 mx-auto mb-2" />
                  <img src={staff.nameSvg} alt={staff.name} class="h-5 mx-auto" />
                </div>
              ))}
            </div>

            <div class="text-center mt-auto">
              <a href="/staff" class="inline-block">
                <img src="/images/svg/Parts/icon_detailHere.svg" alt="詳しくはコチラ" class="h-10 md:h-12 hover:scale-105 transition-transform duration-300" />
              </a>
            </div>
          </div>

          <!-- 2. サービス内容 -->
          <div class="bg-white/95 rounded-2xl shadow-lg p-6 overflow-hidden flex flex-col">
            <!-- セクションタイトル（SVG使用） -->
            <div class="text-center mb-4">
              <img src="/images/svg/Parts/text_service.svg" alt="サービス内容" class="h-7 mx-auto mb-2" />
              <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-3 mx-auto" />
            </div>

            <!-- サービスアイコンとリスト -->
            <div class="flex items-center justify-center gap-4 mb-4 flex-grow">
              <img src="/images/svg/Parts/icon_Services.svg" alt="" class="w-16 h-16 flex-shrink-0" />
              <ul class="space-y-1 text-left">
                {services.map((service) => (
                  <li class="flex items-center">
                    <span class="w-1.5 h-1.5 bg-overview-yellow rounded-full mr-2"></span>
                    <span class="text-overview-dark-blue text-sm font-medium">{service}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="text-center mt-auto">
              <a href="/services" class="inline-block">
                <img src="/images/svg/Parts/icon_detailHere.svg" alt="詳しくはコチラ" class="h-10 md:h-12 hover:scale-105 transition-transform duration-300" />
              </a>
            </div>
          </div>

          <!-- 3. リンクカード（依頼の流れ/よくある質問/活動経歴） -->
          <div class="space-y-3">
            <!-- 依頼の流れ -->
            <a href="/services" class="block bg-white/95 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow text-center">
              <img src="/images/svg/Parts/text_Offer.svg" alt="依頼の流れ" class="h-7 mx-auto mb-3" />
              <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-3 mx-auto" />
            </a>

            <!-- よくある質問 -->
            <a href="/services#faq" class="block bg-white/95 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow text-center">
              <img src="/images/svg/Parts/text_QA.svg" alt="よくある質問" class="h-7 mx-auto mb-3" />
              <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-3 mx-auto" />
            </a>

            <!-- 活動経歴 -->
            <a href="/achievements" class="block bg-white/95 rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow text-center">
              <img src="/images/svg/Parts/text_Carrer.svg" alt="活動経歴" class="h-7 mx-auto mb-3" />
              <img src="/images/svg/Parts/waveLine.svg" alt="" class="h-3 mx-auto" />
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- CTAバナー（QA画像） -->
    <section class="py-12 md:py-16">
      <div class="container mx-auto px-4">
        <a href="/contact" class="block hover:opacity-90 transition-opacity duration-300">
          <img src="/images/svg/Parts/QA.svg" alt="お問い合わせ - 時間・予算・内容、ご相談OKです！" class="w-full max-w-4xl mx-auto" />
        </a>
      </div>
    </section>

    <!-- 区切り線とコピーライト -->
    <div class="py-8">
      <hr class="border-t border-overview-dark-blue/20 mb-4" />
      <p class="text-center text-overview-dark-blue/60 text-sm">© サイエンス＆スペース ラボ DONATI</p>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* 丸みを帯びた親しみやすいフォント調整 */
  body {
    font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', sans-serif;
  }
  
  /* backGround.png を背景として使用 */
  body {
    background-image: url('/images/backGround.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }
  
  /* 背景画像の上に軽いオーバーレイを追加 */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, rgba(135, 206, 235, 0.1) 0%, rgba(255, 215, 0, 0.1) 100%);
    pointer-events: none;
    z-index: -1;
  }

  /* Heroカルーセル専用スタイル */
  .hero-carousel-wrapper {
    margin-top: 0;
    margin-bottom: 2rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1rem;
  }

  .hero-carousel-wrapper .carousel-section {
    padding: 0;
    width: 100%;
  }

  .hero-carousel-wrapper .container {
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    width: 100% !important;
  }

  .hero-carousel-wrapper .carousel-wrapper {
    border-radius: 0;
    margin: 0;
    width: 100%;
    box-shadow: none;
  }

  /* レスポンシブ画像高さ */
  .hero-carousel-wrapper .carousel-slide img {
    height: 400px;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .hero-carousel-wrapper .carousel-slide img {
      height: 500px;
    }
  }

  @media (min-width: 1024px) {
    .hero-carousel-wrapper .carousel-slide img {
      height: 600px;
    }
  }

  /* カルーセルコンテンツを非表示 */
  .hero-carousel-wrapper .carousel-content {
    display: none;
  }

  /* アクティブドットの配色調整 */
  .hero-carousel-wrapper .dot.active {
    background: #f4a261;
  }

  /* ウェーブライン幅調整 */
  .waveline-wrapper {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  /* ホバーエフェクト */
  .hero-carousel-wrapper .carousel-slide {
    cursor: pointer;
  }
</style>